# Copy this file to .env and fill in real values before running.

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Leave unset to use a local sqlite file (zero setup, fine for development).
# For the real submission, point this at your Postgres instance, e.g.:
# DATABASE_URL=postgres://user:password@localhost:5432/meridian_general
DATABASE_URL=

# Comma-separated list of frontend origins allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Password shared by every doctor account.
DOCTOR_SHARED_PASSWORD=doctor

# Password for the single seeded dean account (used by `manage.py seed_dean`).
DEAN_PASSWORD=dean
